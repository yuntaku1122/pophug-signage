#!/usr/bin/env python3
# ============================================
# pophug-update-apply
#
# アップデート処理のうち、root権限が必要な最後の仕上げだけを行う
# 限定ヘルパースクリプト。
#   1. staging_dir/pophug-netctl があれば /usr/local/bin/pophug-netctl を置き換える
#   2. staging_dir/pophug-hostname-setup があれば /usr/local/bin/pophug-hostname-setup を置き換える
#   3. staging_dir/pophug-hostname-setup.service があれば
#      /etc/systemd/system/pophug-hostname-setup.service を置き換え、daemon-reloadする
#   4. staging_dir/pophug-signage.service があれば
#      /etc/systemd/system/pophug-signage.service を置き換え、daemon-reloadする
#      （Type=notify・WatchdogSec等、本体サービスの起動方法自体の設定もここで配信できるようにする）
#   5. pophug-signage.service を再起動する
#
# ファイルの展開・入れ替え・バックアップなど、それ以外の処理は
# 全て非特権側(update_check.py)で行い、ここでは行わない。
#
# インストール:
#   sudo cp scripts/pophug-update-apply /usr/local/bin/
#   sudo chmod 755 /usr/local/bin/pophug-update-apply
#   sudo chown root:root /usr/local/bin/pophug-update-apply
# ============================================

import os
import shutil
import subprocess
import sys
import time

NETCTL_DEST = "/usr/local/bin/pophug-netctl"
HOSTNAME_SETUP_DEST = "/usr/local/bin/pophug-hostname-setup"
HOSTNAME_SERVICE_DEST = "/etc/systemd/system/pophug-hostname-setup.service"
SIGNAGE_SERVICE_DEST = "/etc/systemd/system/pophug-signage.service"


def _install_helper(staging_dir, filename, dest_path, mode=0o755):
    """staging_dir内に該当ファイルがあれば、指定パスへ配置する共通処理"""
    src = os.path.join(staging_dir, filename)
    if not os.path.isfile(src):
        return False
    shutil.copy(src, dest_path)
    os.chmod(dest_path, mode)
    shutil.chown(dest_path, user="root", group="root")
    return True


def main():
    if len(sys.argv) != 2:
        sys.exit("usage: pophug-update-apply <staging_dir>")

    staging_dir = sys.argv[1]
    if not os.path.isdir(staging_dir):
        sys.exit(f"staging dir not found: {staging_dir}")

    if _install_helper(staging_dir, "pophug-netctl", NETCTL_DEST):
        print("pophug-netctl updated")

    if _install_helper(staging_dir, "pophug-hostname-setup", HOSTNAME_SETUP_DEST):
        print("pophug-hostname-setup updated")

    unit_changed = False

    hostname_service_src = os.path.join(staging_dir, "pophug-hostname-setup.service")
    if os.path.isfile(hostname_service_src):
        shutil.copy(hostname_service_src, HOSTNAME_SERVICE_DEST)
        unit_changed = True
        print("pophug-hostname-setup.service updated")

    signage_service_src = os.path.join(staging_dir, "pophug-signage.service")
    if os.path.isfile(signage_service_src):
        shutil.copy(signage_service_src, SIGNAGE_SERVICE_DEST)
        unit_changed = True
        print("pophug-signage.service updated")

    if unit_changed:
        subprocess.run(["systemctl", "daemon-reload"])
        print("daemon-reload done")

    # このスクリプト自身も元をたどれば pophug-signage.service から呼ばれた
    # 子プロセスなので、同じプロセスグループに属している。
    # 素の"systemctl restart"（結果を待つ）はもちろん、"--no-block"（予約だけしてすぐ戻る）
    # でも、予約後ほぼ即座に実際の再起動処理が始まってしまうため、このスクリプト自身が
    # 正常終了して制御を戻すタイミングと僅かに競合し、稀に巻き込まれて強制終了する
    # 不具合が実際に発生した。
    # そこで、再起動処理そのものを「2秒後に発火する、今の処理系統とは完全に独立した
    # 一時的なタイマーユニット」として systemd-run で予約する。これにより、
    # 今の処理系統が全て正常に完了し、Web側に結果を返し終えるまでの
    # 十分な猶予（2秒）を確保してから実際の再起動が始まるようにする。
    unit_name = f"pophug-restart-{int(time.time())}"
    r = subprocess.run([
        "systemd-run", "--collect", "--on-active=2",
        f"--unit={unit_name}",
        "systemctl", "restart", "pophug-signage.service",
    ])
    if r.returncode != 0:
        sys.exit("failed to schedule service restart")
    print(f"service restart scheduled via {unit_name} (in 2s)")


if __name__ == "__main__":
    main()
