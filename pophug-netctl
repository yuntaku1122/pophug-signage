#!/usr/bin/env python3
# ============================================
# pophug-netctl
#
# KitchenCar POP Signageの「Wi-Fiセットアップモード」用の、
# root権限が必要なネットワーク操作だけを行う限定ヘルパースクリプト。
#
# アプリ本体(pophugユーザー)はこのスクリプトだけをsudo経由で呼び出す。
# nmcliを直接野放しにするのではなく、ここで扱えるコマンドと
# 引数の形式を厳しく制限することで、必要最小限の権限だけを与える。
#
# 使い方:
#   pophug-netctl hotspot-start <ssid> <password>
#   pophug-netctl hotspot-stop
#   pophug-netctl scan
#   pophug-netctl connect <ssid> <password>
#
# インストール:
#   sudo cp scripts/pophug-netctl /usr/local/bin/
#   sudo chmod 755 /usr/local/bin/pophug-netctl
#   sudo chown root:root /usr/local/bin/pophug-netctl
# ============================================

import subprocess
import sys

HOTSPOT_CON_NAME = "pophug-setup-ap"


def run(cmd, timeout=30):
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
    except subprocess.TimeoutExpired:
        class _R:
            returncode = 1
            stdout = ""
            stderr = "timeout"
        return _R()


def valid_ssid(ssid):
    """SSIDとして許容できるかを検証する。

    以前は使える文字を [\\w\\-\\. ]（英数字・アンダースコア・ハイフン・ドット・
    スペースのみ）に厳しく制限していたが、これだとiPhoneの個人ホットスポットの
    デフォルト名（例: "Satoru's iPhone"）のようなアポストロフィを含む、ごく普通の
    SSIDまで「invalid ssid」として弾いてしまう不具合があった（実機で発生）。

    nmcliへは配列引数としてそのまま渡しており（shell=Trueではない）、シェル経由の
    コマンドインジェクションのリスクはそもそも無い。ここで防ぐべきなのは以下だけ:
      - 空文字（SSIDとして意味を成さない）
      - Wi-Fi規格上のSSID長の上限（32バイト、UTF-8換算。絵文字や日本語のSSIDは
        1文字が複数バイトになるため、文字数ではなくバイト数で判定する）
      - 制御文字（NUL・改行など。ログや設定ファイルへの書き込みで問題を起こしうる）
      - 先頭が "-" のもの（nmcli自身が値ではなくオプションフラグと誤解する可能性がある）
    """
    if not ssid:
        return False
    if ssid.startswith("-"):
        return False
    if len(ssid.encode("utf-8", errors="surrogatepass")) > 32:
        return False
    if any(ord(c) < 0x20 or ord(c) == 0x7f for c in ssid):
        return False
    return True


def valid_password(password):
    # 空文字(オープンネットワーク)か、WPA2の規格上の範囲(8〜63文字)
    return password == "" or 8 <= len(password) <= 63


def cmd_hotspot_start(args):
    if len(args) != 2:
        sys.exit("usage: hotspot-start <ssid> <password>")
    ssid, password = args
    if not valid_ssid(ssid):
        sys.exit("invalid ssid")
    if not valid_password(password):
        sys.exit("invalid password")

    # 既存の同名プロファイルが残っていれば作り直す
    run(["nmcli", "connection", "delete", HOTSPOT_CON_NAME])

    add_cmd = [
        "nmcli", "connection", "add", "type", "wifi", "ifname", "wlan0",
        "con-name", HOTSPOT_CON_NAME, "autoconnect", "no", "ssid", ssid,
        "802-11-wireless.mode", "ap", "802-11-wireless.band", "bg",
        "ipv4.method", "shared",
    ]
    if password:
        add_cmd += ["wifi-sec.key-mgmt", "wpa-psk", "wifi-sec.psk", password]

    r = run(add_cmd)
    if r.returncode != 0:
        sys.exit(f"failed to create hotspot profile: {r.stderr}")

    r = run(["nmcli", "connection", "up", HOTSPOT_CON_NAME])
    if r.returncode != 0:
        sys.exit(f"failed to activate hotspot: {r.stderr}")

    print("hotspot started")


def cmd_hotspot_stop(args):
    run(["nmcli", "connection", "down", HOTSPOT_CON_NAME])
    run(["nmcli", "connection", "delete", HOTSPOT_CON_NAME])
    print("hotspot stopped")


def cmd_scan(args):
    run(["nmcli", "device", "wifi", "rescan"])
    r = run(["nmcli", "-t", "-f", "SSID,SIGNAL,SECURITY", "device", "wifi", "list"], timeout=20)
    print(r.stdout)


def _delete_connections_for_ssid(ssid):
    """指定SSIDに紐づく既存の接続プロファイルを探して削除する。
    netplanなど別の仕組みで作られた不完全なプロファイルが残っていると、
    'nmcli device wifi connect' がそれを使い回そうとして
    '802-11-wireless-security.key-mgmt: property is missing' のような
    エラーで失敗することがあるため、毎回まっさらな状態から接続し直す。"""
    r = run(["nmcli", "-t", "-f", "NAME,TYPE", "connection", "show"])
    for line in r.stdout.splitlines():
        parts = line.split(":")
        if len(parts) < 2 or parts[1] != "802-11-wireless":
            continue
        name = parts[0]
        if name == HOTSPOT_CON_NAME:
            continue
        ssid_check = run(["nmcli", "-g", "802-11-wireless.ssid", "connection", "show", name])
        if ssid_check.stdout.strip() == ssid:
            run(["nmcli", "connection", "delete", name])


def cmd_connect(args):
    if len(args) not in (2, 3):
        sys.exit("usage: connect <ssid> <password> [hidden]")
    ssid, password = args[0], args[1]
    hidden = len(args) == 3 and args[2] == "hidden"
    if len(args) == 3 and not hidden:
        sys.exit("usage: connect <ssid> <password> [hidden]")
    if not valid_ssid(ssid):
        sys.exit("invalid ssid")
    if not valid_password(password):
        sys.exit("invalid password")

    # Pi Zero 2Wは無線が1系統しか無いため、セットアップ用アクセスポイントと
    # 通常の子機接続を同時には維持できない。接続を試す前に一旦落とす。
    run(["nmcli", "connection", "down", HOTSPOT_CON_NAME])

    _delete_connections_for_ssid(ssid)

    connect_cmd = ["nmcli", "device", "wifi", "connect", ssid]
    if hidden:
        # 一覧に出てこない非表示（ステルス）ネットワーク向け。nmcliに積極的な
        # プローブ接続を指示する。逆に、通常の(ビーコンを出している)ネットワーク
        # に対してこれを付けると、Pi Zero 2Wの無線チップ(brcmfmac)との相性で
        # 接続が不安定になるケースが確認されているため、明示指定時のみ付与する。
        connect_cmd += ["hidden", "yes"]
    if password:
        connect_cmd += ["password", password]
    r = run(connect_cmd, timeout=45)

    if r.returncode != 0:
        # 失敗したらセットアップ用アクセスポイントに戻し、再試行できるようにする
        run(["nmcli", "connection", "up", HOTSPOT_CON_NAME])
        sys.exit(f"connect failed: {r.stderr or r.stdout}")

    run(["nmcli", "connection", "delete", HOTSPOT_CON_NAME])
    print("connected")


COMMANDS = {
    "hotspot-start": cmd_hotspot_start,
    "hotspot-stop": cmd_hotspot_stop,
    "scan": cmd_scan,
    "connect": cmd_connect,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        sys.exit(f"usage: pophug-netctl <{'|'.join(COMMANDS)}> [args...]")
    COMMANDS[sys.argv[1]](sys.argv[2:])


if __name__ == "__main__":
    main()
