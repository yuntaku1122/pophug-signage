#!/usr/bin/env python3
# ============================================
# pophug-hostname-setup
#
# 起動時に、複製されたSDカード特有の「機体固有情報の重複」を解消するスクリプト。
#
# ① SSHホスト鍵が存在しなければ（量産マスターイメージ作成時に削除されている場合）、
#    その場で新規に生成し直す。全台が同じSSH鍵を共有してしまうことを防ぐため。
# ② ホスト名がまだ工場出荷時のデフォルト("pophug")のままであれば、
#    ＝「これは複製直後の初回起動である」とみなし、以下をまとめて行う。
#      - 保存済みのWi-Fi接続情報を削除（複製元の機体のWi-Fi設定を引き継がない）
#      - images/フォルダの中身（写真・表示状態ファイル）を削除（複製元の写真を引き継がない）
#      - 過去のアップデートで残ったバックアップフォルダを削除
#      - wlan0のMACアドレス下4桁を使って機体ごとに一意なホスト名に変更する
#
# 既に初期化済み（ホスト名が変更済み）であれば②は何もしないため、
# 毎回の起動時に実行しても安全（冪等）。
#
# インストール:
#   sudo cp pophug-hostname-setup /usr/local/bin/
#   sudo chmod 755 /usr/local/bin/pophug-hostname-setup
#   sudo cp pophug-hostname-setup.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable pophug-hostname-setup.service
# ============================================

import glob
import os
import shutil
import subprocess
import sys

DEFAULT_HOSTNAME = "pophug"
APP_DIR = "/home/pophug/pophug-signage"
IMAGES_DIR = os.path.join(APP_DIR, "images")

# ハードウェアウォッチドッグ関連
CONFIG_TXT_CANDIDATES = ["/boot/firmware/config.txt", "/boot/config.txt"]
SYSTEM_CONF_PATH = "/etc/systemd/system.conf"
WATCHDOG_DTPARAM_LINE = "dtparam=watchdog=on"
RUNTIME_WATCHDOG_SEC = "15"


def get_current_hostname():
    r = subprocess.run(["hostname"], capture_output=True, text=True)
    return r.stdout.strip()


def get_wlan_mac(iface="wlan0"):
    try:
        with open(f"/sys/class/net/{iface}/address", encoding="utf-8") as f:
            return f.read().strip()
    except OSError:
        return None


def regenerate_ssh_host_keys_if_missing():
    """量産マスターイメージ作成時にSSHホスト鍵を削除してある場合、
    ここで新規に生成し直す。既に鍵が存在する（通常の起動）場合は何もしない。"""
    existing = glob.glob("/etc/ssh/ssh_host_*_key")
    if existing:
        return  # 既に鍵がある(複製直後の初回起動ではない)ので何もしない

    print("SSHホスト鍵が見つからないため、新規に生成します...")
    r = subprocess.run(["ssh-keygen", "-A"])
    if r.returncode != 0:
        print("SSHホスト鍵の生成に失敗しました（無視して続行）")
        return

    subprocess.run(["systemctl", "restart", "ssh"])
    print("SSHホスト鍵を新規生成しました")


def _find_config_txt():
    for path in CONFIG_TXT_CANDIDATES:
        if os.path.isfile(path):
            return path
    return None


def _ensure_dtparam_watchdog(config_txt_path):
    """config.txtに dtparam=watchdog=on が無ければ追記する（bcm2835_wdtカーネルドライバを
    有効化し、/dev/watchdogを使えるようにするため）。既にあれば何もしない。
    戻り値: 新たに追記したかどうか。"""
    try:
        with open(config_txt_path, "r", encoding="utf-8") as f:
            content = f.read()
    except OSError as e:
        print(f"{config_txt_path} の読み込みに失敗しました（無視して続行）: {e}")
        return False

    for line in content.splitlines():
        if line.strip() == WATCHDOG_DTPARAM_LINE:
            return False  # 既に設定済み

    try:
        with open(config_txt_path, "a", encoding="utf-8") as f:
            if content and not content.endswith("\n"):
                f.write("\n")
            f.write(WATCHDOG_DTPARAM_LINE + "\n")
    except OSError as e:
        print(f"{config_txt_path} への書き込みに失敗しました（無視して続行）: {e}")
        return False
    print(f"{config_txt_path} に {WATCHDOG_DTPARAM_LINE} を追加しました")
    return True


def _ensure_runtime_watchdog_sec():
    """/etc/systemd/system.conf の [Manager] セクションに RuntimeWatchdogSec を設定する。
    systemd(PID1)自身がハードウェアウォッチドッグを定期的に「無事です」と叩き続け、
    カーネルごと完全にフリーズしてsystemdすら応答しなくなった場合に、指定秒数後
    ハードウェアが強制的に再起動をかけてくれるようになる。
    既に何らかの値が設定されていれば（意図的な変更の可能性があるため）上書きしない。
    戻り値: 新たに設定したかどうか。"""
    try:
        with open(SYSTEM_CONF_PATH, "r", encoding="utf-8") as f:
            lines = f.readlines()
    except OSError as e:
        print(f"{SYSTEM_CONF_PATH} の読み込みに失敗しました（無視して続行）: {e}")
        return False

    for line in lines:
        stripped = line.strip()
        if stripped.startswith("RuntimeWatchdogSec=") and not stripped.startswith("#"):
            return False  # 既に何らかの値が設定済み

    new_lines = list(lines)
    inserted = False
    for i, line in enumerate(new_lines):
        if line.strip() == "[Manager]":
            new_lines.insert(i + 1, f"RuntimeWatchdogSec={RUNTIME_WATCHDOG_SEC}\n")
            inserted = True
            break
    if not inserted:
        # [Manager]セクション自体が見つからない場合（コメントのみのファイル等）は
        # ファイル先頭に新設する
        new_lines = [f"[Manager]\nRuntimeWatchdogSec={RUNTIME_WATCHDOG_SEC}\n\n"] + new_lines

    try:
        with open(SYSTEM_CONF_PATH, "w", encoding="utf-8") as f:
            f.writelines(new_lines)
    except OSError as e:
        print(f"{SYSTEM_CONF_PATH} への書き込みに失敗しました（無視して続行）: {e}")
        return False
    print(f"{SYSTEM_CONF_PATH} に RuntimeWatchdogSec={RUNTIME_WATCHDOG_SEC} を設定しました")
    return True


def ensure_hardware_watchdog_enabled():
    """カーネルごとの完全なフリーズ（アプリだけでなくOS全体が応答しなくなるケース）に
    備え、ハードウェアウォッチドッグ（bcm2835_wdtドライバ + systemdのRuntimeWatchdogSec）
    を有効化する。

    量産マスターイメージの時点で既に設定済みなら、複製した各機体では何もしない
    （＝通常運用中に毎回この処理が走るわけではない）。まだ設定されていない機体
    （このコード自体を後から適用した既存機体など）でだけ設定を追加し、有効化には
    再起動が必要なため、この処理の中で完結させるようその場で再起動する。
    起動シーケンス上、この処理はpophug-signage.serviceより前に実行されるので、
    サイネージ画面が表示される前に再起動しても利用者への影響は無い。"""
    changed = False

    config_txt = _find_config_txt()
    if config_txt:
        changed = _ensure_dtparam_watchdog(config_txt) or changed
    else:
        print("config.txtが見つからないため、dtparam=watchdog=onの設定をスキップしました")

    changed = _ensure_runtime_watchdog_sec() or changed

    if changed:
        print("ハードウェアウォッチドッグの設定を追加しました。反映のため再起動します...")
        subprocess.run(["/sbin/reboot"])
        sys.exit(0)  # reboot呼び出し後、実際にシステムが落ちるまでの間もここで処理を止めておく


def clear_saved_wifi_connections():
    """保存済みのWi-Fi接続プロファイルを全て削除する
    （複製元の機体が繋いでいたWi-Fi情報を引き継がないようにするため）。"""
    try:
        r = subprocess.run(
            ["nmcli", "-t", "-f", "NAME,TYPE", "connection", "show"],
            capture_output=True, text=True, timeout=10,
        )
    except Exception as e:
        print(f"Wi-Fi接続一覧の取得に失敗しました（無視して続行）: {e}")
        return

    for line in r.stdout.splitlines():
        parts = line.split(":")
        if len(parts) >= 2 and parts[1] == "802-11-wireless":
            name = parts[0]
            print(f"保存済みWi-Fi接続を削除します: {name}")
            subprocess.run(["nmcli", "connection", "delete", name], capture_output=True)


def clear_images_folder():
    """images/フォルダの中身（写真・表示状態ファイルなど）を全て消去する
    （複製元の機体の写真やデータを引き継がないようにするため）。フォルダ自体は残す。"""
    if not os.path.isdir(IMAGES_DIR):
        return
    for name in os.listdir(IMAGES_DIR):
        path = os.path.join(IMAGES_DIR, name)
        try:
            if os.path.isdir(path):
                shutil.rmtree(path)
            else:
                os.remove(path)
        except OSError as e:
            print(f"{path} の削除に失敗しました（無視して続行）: {e}")
    print("images/フォルダの中身を消去しました")


def clear_update_backups():
    """過去のアップデートで残ったバックアップフォルダ(.backup-*)を削除する"""
    for path in glob.glob(os.path.join(APP_DIR, ".backup-*")):
        try:
            shutil.rmtree(path)
        except OSError:
            pass


def update_etc_hosts(new_hostname):
    """/etc/hosts の 127.0.1.1 行を新しいホスト名に更新する。
    これが無いままだと、一部のコマンド（sudoなど）が自分自身のホスト名を
    名前解決できずに警告を出すことがあるため。"""
    try:
        with open("/etc/hosts", "r", encoding="utf-8") as f:
            lines = f.readlines()
    except OSError as e:
        print(f"/etc/hosts の読み込みに失敗しました（無視して続行）: {e}")
        return

    new_lines = []
    replaced = False
    for line in lines:
        if line.startswith("127.0.1.1"):
            new_lines.append(f"127.0.1.1\t{new_hostname}\n")
            replaced = True
        else:
            new_lines.append(line)
    if not replaced:
        new_lines.append(f"127.0.1.1\t{new_hostname}\n")

    try:
        with open("/etc/hosts", "w", encoding="utf-8") as f:
            f.writelines(new_lines)
    except OSError as e:
        print(f"/etc/hosts の書き込みに失敗しました（無視して続行）: {e}")


def main():
    regenerate_ssh_host_keys_if_missing()
    ensure_hardware_watchdog_enabled()

    current = get_current_hostname()
    if current != DEFAULT_HOSTNAME:
        print(f"ホスト名は既に変更済みです（{current}）。何もしません。")
        return

    print("初回起動を検知しました（ホスト名が初期値のまま）。機体固有の情報を初期化します...")
    clear_saved_wifi_connections()
    clear_images_folder()
    clear_update_backups()

    mac = get_wlan_mac()
    if not mac:
        print("wlan0のMACアドレスが取得できなかったため、ホスト名は変更しません"
              "（次回起動時に再試行されます）。")
        sys.exit(1)

    suffix = mac.replace(":", "").upper()[-4:]
    new_hostname = f"{DEFAULT_HOSTNAME}-{suffix}"

    r = subprocess.run(["hostnamectl", "set-hostname", new_hostname])
    if r.returncode != 0:
        sys.exit("hostnamectl でのホスト名変更に失敗しました")

    update_etc_hosts(new_hostname)
    print(f"ホスト名を {new_hostname} に変更しました（MAC: {mac}）")
    print("初期化が完了しました。")


if __name__ == "__main__":
    main()
